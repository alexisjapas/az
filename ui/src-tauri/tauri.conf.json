{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AZ",
  "version": "0.1.0",
  "identifier": "dev.az.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AZ",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Assistant personnel local-first",
    "longDescription": "Capture vocale et textuelle, segmentation LLM, faits typés validés, recherche sémantique — tout local et chiffré."
  }
}
